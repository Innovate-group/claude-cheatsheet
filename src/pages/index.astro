---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SearchBar from '../components/SearchBar.astro';
import FilterChips from '../components/FilterChips.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Footer from '../components/Footer.astro';
---
<Layout>
  <main>
    <Hero />

    <div id="sticky-sentinel" aria-hidden="true"></div>
    <div class="sticky-bar sticky top-0 z-20 border-b border-line">
      <div class="max-w-6xl mx-auto px-6 py-3 sm:py-3 flex flex-col sm:flex-row gap-3 sm:items-center">
        <SearchBar />
        <div class="flex items-center gap-3 sm:flex-shrink-0">
          <FilterChips />
          <ThemeToggle class="hidden sm:inline-flex" />
        </div>
      </div>
    </div>

    <div id="upload-error" class="max-w-6xl mx-auto px-6 pt-4 text-[13px] text-red-600" hidden></div>

    <!-- Empty state: shown until the user loads a JSON -->
    <div id="empty-state" class="max-w-6xl mx-auto px-6 py-10 sm:py-16">
      <div class="border border-dashed border-line rounded-md px-5 py-10 sm:px-10 sm:py-16 text-center bg-[var(--card)]">
        <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted">Paso 1 · En tu Mac</p>
        <h2 class="mt-3 text-2xl sm:text-3xl font-semibold tracking-tight">
          Generá tu cheatsheet<span class="text-accent">.</span>
        </h2>
        <p class="mt-4 max-w-xl mx-auto text-[14px] text-muted leading-relaxed">
          Bajá el script y ejecutalo con Node. Lee tu carpeta <span class="font-mono text-fg">~/.claude</span>
          y guarda el resultado en un JSON.
        </p>

        <div class="mt-6 max-w-2xl mx-auto flex flex-col sm:flex-row items-stretch gap-2">
          <pre class="flex-1 text-left font-mono text-[12px] bg-bg border border-line rounded-md p-3 overflow-x-auto whitespace-pre-wrap sm:whitespace-pre break-all sm:break-normal"><code data-download-cmd>curl -sSL … -o claude-cheatsheet.mjs &amp;&amp; node claude-cheatsheet.mjs &gt; cheatsheet.json</code></pre>
          <button
            type="button"
            data-copy-cmd
            class="flex-shrink-0 px-3 py-2 text-[12px] font-mono uppercase tracking-[0.1em] border border-line rounded-md hover:border-fg transition-colors"
          >
            Copiar
          </button>
        </div>

        <p class="mt-10 font-mono text-[11px] uppercase tracking-[0.18em] text-muted">Paso 2 · Acá</p>
        <h3 class="mt-3 text-lg font-medium">Arrastrá el JSON a esta página.</h3>
        <div class="mt-5">
          <button
            type="button"
            data-upload-trigger
            class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-fg text-bg text-[13px] font-medium hover:opacity-90 transition-opacity"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="17 8 12 3 7 8" />
              <line x1="12" y1="3" x2="12" y2="15" />
            </svg>
            Subir JSON
          </button>
        </div>
      </div>
    </div>

    <div id="sections-root" class="max-w-6xl mx-auto px-6 py-10 space-y-14" hidden>
      <section data-reveal data-section-wrap data-kind="command" data-collapsed="false" style="--reveal-delay: 0ms">
        <button type="button" class="section-toggle" aria-expanded="true" aria-controls="cards-command">
          <span class="flex items-baseline gap-2">
            <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted">Slash commands</span>
            <span class="font-mono text-[11px] text-muted tabular-nums" data-filter-count="command">0</span>
          </span>
          <span class="chevron" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </span>
        </button>
        <div class="section-body">
          <div class="section-body-inner">
            <div id="cards-command" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" data-section="command"></div>
          </div>
        </div>
      </section>

      <section data-reveal data-section-wrap data-kind="skill" data-collapsed="false" style="--reveal-delay: 80ms">
        <button type="button" class="section-toggle" aria-expanded="true" aria-controls="cards-skill">
          <span class="flex items-baseline gap-2">
            <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted">Skills</span>
            <span class="font-mono text-[11px] text-muted tabular-nums" data-filter-count="skill">0</span>
          </span>
          <span class="chevron" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </span>
        </button>
        <div class="section-body">
          <div class="section-body-inner">
            <div id="cards-skill" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" data-section="skill"></div>
          </div>
        </div>
      </section>

      <section data-reveal data-section-wrap data-kind="plugin" data-collapsed="false" style="--reveal-delay: 160ms">
        <button type="button" class="section-toggle" aria-expanded="true" aria-controls="cards-plugin">
          <span class="flex items-baseline gap-2">
            <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted">Plugins disponibles</span>
            <span class="font-mono text-[11px] text-muted tabular-nums" data-filter-count="plugin">0</span>
          </span>
          <span class="chevron" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </span>
        </button>
        <div class="section-body">
          <div class="section-body-inner">
            <div id="cards-plugin" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" data-section="plugin"></div>
          </div>
        </div>
      </section>

      <section data-reveal data-section-wrap data-kind="agent" data-collapsed="false" style="--reveal-delay: 240ms">
        <button type="button" class="section-toggle" aria-expanded="true" aria-controls="cards-agent">
          <span class="flex items-baseline gap-2">
            <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted">Agents</span>
            <span class="font-mono text-[11px] text-muted tabular-nums" data-filter-count="agent">0</span>
          </span>
          <span class="chevron" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </span>
        </button>
        <div class="section-body">
          <div class="section-body-inner">
            <div id="cards-agent" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" data-section="agent"></div>
          </div>
        </div>
      </section>

      <div id="no-results" class="hidden border border-dashed border-line rounded-md p-10 text-center">
        <p class="font-mono text-[12px] uppercase tracking-[0.14em] text-muted">Sin resultados</p>
        <p class="mt-2 text-[13px] text-muted">Probá otra búsqueda o cambiá el filtro.</p>
      </div>
    </div>
    <!-- /sections-root -->

    <Footer />
  </main>

  <!-- Detail modal / bottom-sheet -->
  <div id="modal-root" class="modal-root" hidden aria-hidden="true">
    <div class="modal-backdrop" data-modal-close></div>
    <div
      class="modal-sheet"
      role="dialog"
      aria-modal="true"
      aria-labelledby="modal-title"
      tabindex="-1"
    >
      <span class="modal-drag-handle" aria-hidden="true"></span>
      <button
        type="button"
        class="modal-close"
        data-modal-close
        aria-label="Cerrar"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
      <div class="modal-body">
        <div class="modal-head">
          <span data-modal-type class="modal-type-pill"></span>
          <button
            type="button"
            class="fav-btn"
            data-modal-fav
            aria-label="Agregar a favoritos"
            aria-pressed="false"
          >
            <svg class="star-outline" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
            </svg>
            <svg class="star-filled" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
            </svg>
          </button>
        </div>
        <h2 id="modal-title" data-modal-title class="modal-title"></h2>
        <p data-modal-desc class="modal-desc" hidden></p>
        <dl data-modal-meta class="modal-meta"></dl>
        <div data-modal-counts class="modal-counts" hidden></div>
        <p data-modal-source class="modal-source" hidden></p>
      </div>
    </div>
  </div>

  <template id="modal-meta-row-tpl">
    <div class="modal-meta-row">
      <dt data-meta-label></dt>
      <dd data-meta-value></dd>
    </div>
  </template>

  <!-- Card template used by hydrate.ts -->
  <template id="card-tpl">
    <article
      data-card
      style="--i: 0"
      class="group rounded-md border border-line bg-[var(--card)] py-2 px-[0.8rem] flex flex-col gap-2.5 min-h-[140px]"
    >
      <div class="flex items-center justify-between gap-2">
        <span class="card-type-pill font-mono text-[10px] uppercase tracking-[0.14em] px-2 py-0.5 rounded"></span>
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="fav-btn"
            aria-label="Agregar a favoritos"
            aria-pressed="false"
            data-fav-toggle
          >
            <svg class="star-outline" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
            </svg>
            <svg class="star-filled" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
            </svg>
          </button>
        </div>
      </div>
      <h3 class="card-name font-mono text-[15px] font-semibold leading-tight break-words"></h3>
      <p class="card-desc text-[13px] text-muted leading-snug clamp-3"></p>
      <p class="card-source mt-auto pt-1.5 font-mono text-[10px] uppercase tracking-[0.12em] text-muted border-t border-line/50"></p>
    </article>
  </template>

  <script>
    import '../scripts/hydrate.ts';
  </script>
</Layout>
